# Mixed hub N=4: hub takes a fluid (water) AND fans an item belt to 4 consumers.
# STATUS (engine 03798ac): PASS (verifies)

input iron : iron-plate
input cu : copper-plate
fluid water : water
assembler cable : copper-cable
chemical hub : electronic-circuit
assembler c0 : advanced-circuit
assembler c1 : advanced-circuit
assembler c2 : advanced-circuit
assembler c3 : advanced-circuit
output out
cu -> cable
iron -> hub
cable -> hub
water ~> hub
hub -> c0, c1, c2, c3
c0, c1, c2, c3 -> out
