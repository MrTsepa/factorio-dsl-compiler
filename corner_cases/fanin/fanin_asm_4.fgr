# High fan-in N=4 into a single 3x3 assembler, then to output.
# STATUS (engine 42133f5): PASS (verifies)

input iron : iron-plate
assembler p0 : copper-cable
assembler p1 : copper-cable
assembler p2 : copper-cable
assembler p3 : copper-cable
assembler sink : advanced-circuit
output out
iron -> p0, p1, p2, p3
p0, p1, p2, p3 -> sink
sink -> out
