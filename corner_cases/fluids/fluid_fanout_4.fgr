# Fluid fan-out N=4: one petroleum source piped to 4 plastic plants + 1 coal belt.
# STATUS (engine 42133f5): PASS (verifies)

fluid petroleum : petroleum-gas
input coal : coal
chemical p0 : plastic-bar
chemical p1 : plastic-bar
chemical p2 : plastic-bar
chemical p3 : plastic-bar
output out
petroleum ~> p0, p1, p2, p3
coal -> p0, p1, p2, p3
p0, p1, p2, p3 -> out
