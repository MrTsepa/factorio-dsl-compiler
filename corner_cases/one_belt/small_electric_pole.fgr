# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of small-electric-pole. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     copper_plate : copper-plate
input     wood : wood
assembler copper_cable : copper-cable
assembler small_electric_pole : small-electric-pole
output    out @ 15.0/s

copper_plate -> copper_cable
wood -> small_electric_pole
copper_cable -> small_electric_pole
small_electric_pole -> out
