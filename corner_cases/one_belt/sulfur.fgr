# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of sulfur. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

fluid     petroleum_gas_src : petroleum-gas
fluid     water_src : water
chemical  sulfur : sulfur
output    out @ 15.0/s

water_src ~> sulfur
petroleum_gas_src ~> sulfur
sulfur -> out
