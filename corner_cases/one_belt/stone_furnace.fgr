# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of stone-furnace. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     stone : stone
assembler stone_furnace : stone-furnace
output    out @ 15.0/s

stone -> stone_furnace
stone_furnace -> out
