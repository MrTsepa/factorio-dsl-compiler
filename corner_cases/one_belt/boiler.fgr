# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of boiler. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_plate : iron-plate
input     stone : stone
assembler stone_furnace : stone-furnace
assembler pipe : pipe
assembler boiler : boiler
output    out @ 1/s

stone -> stone_furnace
iron_plate -> pipe
stone_furnace -> boiler
pipe -> boiler
boiler -> out
