# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of concrete. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_ore : iron-ore
input     stone : stone
fluid     water_src : water
furnace   stone_brick : stone-brick
assembler concrete : concrete
output    out @ 15.0/s

stone -> stone_brick
stone_brick -> concrete
iron_ore -> concrete
water_src ~> concrete
concrete -> out
