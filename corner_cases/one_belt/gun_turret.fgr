# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of gun-turret. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     copper_plate : copper-plate
input     iron_plate : iron-plate
assembler iron_gear_wheel : iron-gear-wheel
assembler gun_turret : gun-turret
output    out @ 15.0/s

iron_plate -> iron_gear_wheel
iron_gear_wheel -> gun_turret
copper_plate -> gun_turret
iron_plate -> gun_turret
gun_turret -> out
