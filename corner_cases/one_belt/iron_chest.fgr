# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of iron-chest. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_plate : iron-plate
assembler iron_chest : iron-chest
output    out @ 15.0/s

iron_plate -> iron_chest
iron_chest -> out
