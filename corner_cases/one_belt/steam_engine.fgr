# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of steam-engine. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_plate : iron-plate
assembler iron_gear_wheel : iron-gear-wheel
assembler pipe : pipe
assembler steam_engine : steam-engine
output    out @ 1/s

iron_plate -> iron_gear_wheel
iron_plate -> pipe
iron_gear_wheel -> steam_engine
pipe -> steam_engine
iron_plate -> steam_engine
steam_engine -> out
