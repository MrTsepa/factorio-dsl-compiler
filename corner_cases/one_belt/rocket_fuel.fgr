# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of rocket-fuel. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     solid_fuel : solid-fuel
fluid     light_oil_src : light-oil
assembler rocket_fuel : rocket-fuel
output    out @ 15.0/s

solid_fuel -> rocket_fuel
light_oil_src ~> rocket_fuel
rocket_fuel -> out
