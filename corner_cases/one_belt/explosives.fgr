# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of explosives. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     coal : coal
fluid     petroleum_gas_src : petroleum-gas
fluid     water_src : water
chemical  sulfur : sulfur
chemical  explosives : explosives
output    out @ 15.0/s

water_src ~> sulfur
petroleum_gas_src ~> sulfur
sulfur -> explosives
coal -> explosives
water_src ~> explosives
explosives -> out
