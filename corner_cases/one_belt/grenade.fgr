# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of grenade. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     coal : coal
input     iron_plate : iron-plate
assembler grenade : grenade
output    out @ 15.0/s

iron_plate -> grenade
coal -> grenade
grenade -> out
