# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of storage-tank. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_plate : iron-plate
furnace   steel_plate : steel-plate
assembler storage_tank : storage-tank
output    out @ 15.0/s

iron_plate -> steel_plate
iron_plate -> storage_tank
steel_plate -> storage_tank
storage_tank -> out
