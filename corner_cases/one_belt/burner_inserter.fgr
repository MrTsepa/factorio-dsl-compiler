# ONE-BELT suite (generated by scripts/belt_suite.py): a full yellow
# belt (15/s) of burner-inserter. Recipe tree from the game dumps; raws arrive
# by belt, fluids by boundary source.

input     iron_plate : iron-plate
assembler iron_gear_wheel : iron-gear-wheel
assembler burner_inserter : burner-inserter
output    out @ 15.0/s

iron_plate -> iron_gear_wheel
iron_plate -> burner_inserter
iron_gear_wheel -> burner_inserter
burner_inserter -> out
